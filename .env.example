# ─────────────────────────────────────────────
# 1) Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# 2) 국장 (KRX) - 한국투자증권 KIS Developers
# 발급: https://apiportal.koreainvestment.com/
# ─────────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=

# ─────────────────────────────────────────────
# 3) 국장 거시 - 한국은행 ECOS API
# 발급: https://ecos.bok.or.kr/ → 개발자 서비스
# ─────────────────────────────────────────────
ECOS_API_KEY=

# ─────────────────────────────────────────────
# 4) 미장 심리/분석 - Finnhub
# 발급: https://finnhub.io/ (무료 플랜)
# ─────────────────────────────────────────────
FINNHUB_API_KEY=

# ─────────────────────────────────────────────
# 5) 미장 거시 - FRED (Federal Reserve)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
# Python 스크립트(scripts/collect_fred.py)에서 사용
# ─────────────────────────────────────────────
FRED_API_KEY=

# ─────────────────────────────────────────────
# 6) AI 분석
# ─────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# 7) 인증 (추후 NextAuth 연동 시)
# ─────────────────────────────────────────────
JWT_SECRET=
NEXTAUTH_URL=

# ─────────────────────────────────────────────
# 8) Cron 보안 (Vercel Cron Jobs)
# Vercel Dashboard → Settings → Environment Variables에 동일값 등록
# 미설정 시 로컬 개발에서 인증 우회 (편의상)
# ─────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────
